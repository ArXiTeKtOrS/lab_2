     "output_type": "stream",
     "text": [
      "[[False False  True  True]\n",
      " [ True  True  True False]\n",
      " [False False  True  True]]\n",
      "[[3 4 5 6 7 5 7]]\n"
     ]
    }
   ],
   "source": [
    "mod_m = np.logical_and(m>=3, m<=7)\n",
    "print(mod_m)\n",
    "print(m[mod_m])"
   ]
  },
